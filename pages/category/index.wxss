page {
  padding-bottom: 0;
}

.page {
  display: flex;
  height: 100vh;
  background: #f5f5f5;
}

/* Sidebar */
.sidebar {
  width: 180rpx;
  background: #f0f0f0;
  flex-shrink: 0;
  padding-top: 16rpx;
}

.sidebar-item {
  padding: 28rpx 16rpx;
  font-size: 26rpx;
  color: #666;
  text-align: center;
  line-height: 1.4;
  border-left: 6rpx solid transparent;
}

.sidebar-item--active {
  background: #fff;
  color: #333;
  font-weight: 600;
  border-left-color: #FF5F15;
}

/* Content panel */
.content {
  flex: 1;
  height: 100vh;
  background: #fff;
  padding: 32rpx 28rpx;
  box-sizing: border-box;
}

.content-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 关于领养 */
.content-section {
  margin-bottom: 32rpx;
}

.section-heading {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.section-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

.step-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.step-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #FF5F15;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 16rpx;
  margin-top: 4rpx;
}

.step-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.7;
  flex: 1;
}

/* 领养协议 */
.agreement-intro {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 24rpx;
  line-height: 1.6;
}

.agreement-section {
  margin-bottom: 28rpx;
}

.agreement-heading {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.agreement-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.9;
}

.agreement-footer {
  margin-top: 32rpx;
  padding: 20rpx;
  background: #fff8f5;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #FF5F15;
  text-align: center;
  line-height: 1.6;
}

/* 领养信息 form */
.form-intro {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 24rpx;
  line-height: 1.6;
}

.form-section {
  margin-bottom: 28rpx;
}

.form-section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item--column {
  flex-direction: column;
  align-items: flex-start;
}

.form-label {
  font-size: 26rpx;
  color: #555;
  width: 140rpx;
  flex-shrink: 0;
}

.form-item--column .form-label {
  margin-bottom: 12rpx;
  width: auto;
}

.form-input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  text-align: right;
}

.form-textarea {
  width: 100%;
  height: 140rpx;
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  background: #f9f9f9;
  border-radius: 8rpx;
  padding: 16rpx;
  box-sizing: border-box;
}

.radio-group {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  flex: 1;
  justify-content: flex-end;
}

.radio-item {
  font-size: 22rpx;
  color: #666;
  padding: 8rpx 16rpx;
  border: 1rpx solid #ddd;
  border-radius: 32rpx;
}

.radio-item--active {
  color: #FF5F15;
  border-color: #FF5F15;
  background: #fff8f5;
}

.submit-btn {
  margin-top: 32rpx;
  background: #FF5F15;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 40rpx;
}

.contact-email {
  margin-top: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #FF5F15;
  text-decoration: underline;
}
