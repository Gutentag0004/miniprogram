.container {
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.hero {
  background: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 32rpx 48rpx;
}

.hero-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.hero-subtitle {
  font-size: 26rpx;
  color: #999;
}

.section {
  background: #fff;
  margin: 16rpx 24rpx 0;
  border-radius: 16rpx;
  padding: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.section-body {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}

.contact-label {
  font-size: 26rpx;
  color: #999;
  width: 80rpx;
}

.contact-value {
  font-size: 26rpx;
  color: #333;
}
